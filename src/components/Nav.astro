---
import Icon from "./Icon.astro";
interface Props { data: any; }
const { data } = Astro.props;
---
<header class="nav" id="nav">
  <div class="nav__inner">
    <a class="brand" href="/" aria-label={`${data.brandLine1} — ${data.brandLine2}`}>
      <img class="brand__logo" src={data.logo} alt={`${data.brandLine1} — ${data.brandLine2}`} width="1268" height="421" decoding="async" />
    </a>

    <nav aria-label="Primary">
      <ul class="nav__links">
        {data.links.map((l: any) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <a class="nav__cta" href={data.ctaHref}>{data.ctaLabel}</a>

    <button class="nav__toggle" id="navToggle" aria-label="Open menu" aria-controls="navMobile">
      <Icon name="menu" class="icon" />
    </button>
  </div>

  <div class="nav__mobile" id="navMobile">
    {data.links.map((l: any) => (
      <a href={l.href}>{l.label}</a>
    ))}
    <a class="btn" href={data.ctaHref}>{data.ctaLabel}</a>
  </div>
</header>
