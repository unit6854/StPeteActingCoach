---
import Icon from "./Icon.astro";
import Socials from "./Socials.astro";
interface Props { data: any; social: any; }
const { data, social } = Astro.props;
---
<section class="section contact" id="contact">
  <div class="container">
    <p class="eyebrow reveal">{data.eyebrow}</p>
    <h2 class="contact__title reveal" data-delay="1">{data.heading}</h2>
    <p class="contact__text reveal" data-delay="1">{data.text}</p>

    <div class="contact__actions reveal" data-delay="2">
      <a class="btn" href={`mailto:${data.email}`}>{data.ctaLabel}</a>
      <a class="contact__chip" href={`mailto:${data.email}`}>
        <Icon name="mail" class="icon" /> {data.email}
      </a>
      <a class="contact__chip" href={`tel:${data.phone.replace(/[^0-9+]/g, "")}`}>
        <Icon name="phone" class="icon" /> {data.phone}
      </a>
    </div>

    <div class="reveal" data-delay="2">
      <Socials items={social} align="center" />
    </div>
  </div>
</section>
