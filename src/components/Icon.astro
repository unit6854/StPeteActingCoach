---
/**
 * Gold line-art icon set. Pick an icon with `name` (matches the values used in
 * homepage.json). Stroke inherits `currentColor` so colour is controlled by CSS.
 */
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = "" } = Astro.props;

const paths: Record<string, string> = {
