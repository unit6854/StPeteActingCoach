  play: '<path d="M8 5.5v13l11-6.5-11-6.5Z" fill="currentColor" stroke="none"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M4 7l8 6 8-6"/>',
  phone:
    '<path d="M5 4h3l1.5 5-2 1.5a11 11 0 0 0 5 5l1.5-2 5 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z"/>',
  facebook:
    '<path d="M14 8.5V6.8c0-.8.3-1.3 1.4-1.3H17V2.6C16.5 2.5 15.5 2.4 14.4 2.4c-2.4 0-3.9 1.4-3.9 4v2.1H8v3h2.5V22h3.5v-9.5h2.6l.4-3H14Z" fill="currentColor" stroke="none"/>',
  linkedin:
    '<rect x="2.5" y="2.5" width="19" height="19" rx="2.5"/><path d="M7 10v7M7 7v.01M11 17v-4c0-1.4 1-2.2 2.2-2.2S16 11.6 16 13v4" fill="none"/><circle cx="7" cy="6.9" r="0.4" fill="currentColor" stroke="none"/>',
