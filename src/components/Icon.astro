  camera:
    '<rect x="2" y="7" width="13" height="11" rx="1.5"/><path d="M15 11l6-3.2v8.4L15 13"/><circle cx="7.5" cy="12.5" r="2.4"/>',
  star:
    '<path d="M12 3.5l2.4 5 5.5.7-4 3.8 1 5.4L12 16.9 7.1 18.4l1-5.4-4-3.8 5.5-.7Z"/>',
  chair:
    '<path d="M6 6h12M7 6v6M17 6v6M5 12h14M6 21l7-9M18 21l-7-9"/>',
  book:
    '<path d="M12 6c-1.6-1.2-3.6-1.8-6-1.8V17c2.4 0 4.4.6 6 1.8 1.6-1.2 3.6-1.8 6-1.8V4.2c-2.4 0-4.4.6-6 1.8Z"/><path d="M12 6v12.8"/>',
