  close: '<path d="M6 6l12 12M18 6L6 18"/>',
};

const d = paths[name] ?? "";
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={d}
/>
