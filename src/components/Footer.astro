---
import Socials from "./Socials.astro";
interface Props { data: any; nav: any; contact: any; social: any; }
const { data, nav, contact, social } = Astro.props;
---
<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__intro">
        <a class="footer__brand" href="/" aria-label={`${data.brandLine1} — ${data.brandLine2}`}>
          <img class="footer__logo" src={data.logo} alt={`${data.brandLine1} — ${data.brandLine2}`} />
        </a>
        <p class="footer__tagline">{data.tagline}</p>
        <Socials items={social} align="left" />
      </div>

      <div class="footer__links">
        <div class="footer__col">
          <h4>Explore</h4>
          {nav.links.map((l: any) => (<a href={l.href}>{l.label}</a>))}
        </div>
        <div class="footer__col">
          <h4>Contact</h4>
          <a href={`mailto:${contact.email}`}>{contact.email}</a>
          <a href={`tel:${contact.phone.replace(/[^0-9+]/g, "")}`}>{contact.phone}</a>
          <p>{contact.location}</p>
        </div>
      </div>
    </div>

    <div class="footer__bottom">{data.copyright}</div>
  </div>
</footer>
