---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import data from "../content/homepage.json";

// Load every gallery entry authored through Decap CMS
const modules = import.meta.glob("../content/gallery/*.json", { eager: true });
let items = Object.values(modules).map((m: any) => m.default ?? m);
items = items
  .filter((it: any) => it && it.media)
  .sort(
    (a: any, b: any) =>
      new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime()
  );

const isVideo = (src: string) =>
  /\.(mp4|webm|ogg|ogv|mov|m4v|mkv)$/i.test(src || "");
---
<Layout
  title="Gallery | St. Pete Acting Coach — Gillian Arnold Atlas"
  description="See the work of St. Petersburg on-camera acting coach Gillian Arnold Atlas — photos and video from private coaching, workshops, and student scenes in Tampa Bay."
>
  <Nav data={data.nav} />

  <main class="gallery">
    <header class="container gallery__head">
      <p class="eyebrow reveal">Portfolio</p>
      <h1 class="gallery__title reveal" data-delay="1">The Gallery</h1>
      <div class="divider-gold reveal" data-delay="1"></div>
      <p class="gallery__intro reveal" data-delay="2">
        A look at the work of St. Petersburg on-camera acting coach Gillian
        Arnold Atlas — on set, in the studio, and behind the camera. Browse
        moments from private coaching sessions, the Taking Direction workshop,
        and student scenes across the Tampa Bay area.
      </p>
    </header>

    <div class="container">
      {items.length === 0 ? (
        <p class="gallery__empty">New work is being added soon.</p>
      ) : (
        <div class="gallery__grid">
          {items.map((item: any, i: number) => (
            <figure
              class="gallery__item reveal"
              data-delay={String((i % 4) + 1)}
              data-media={item.media}
              data-video={isVideo(item.media) ? "1" : "0"}
              data-caption={item.caption ?? ""}
            >
              {isVideo(item.media) ? (
                <div class="gallery__videowrap">
                  <video
                    class="gallery__media"
                    src={item.media}
                    muted
                    loop
                    playsinline
                    preload="metadata"
                  ></video>
                  <span class="gallery__play" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.5v13l11-6.5-11-6.5Z"/></svg>
                  </span>
                </div>
              ) : (
                <>
                  <img
                    class="gallery__media"
                    src={item.media}
                    alt={item.caption || "Gallery image"}
                    loading="lazy"
                  />
                  <span class="gallery__zoom" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="6"/><path d="M20 20l-3.4-3.4"/></svg>
                  </span>
                </>
              )}
              {item.caption && (
                <figcaption class="gallery__caption">{item.caption}</figcaption>
              )}
            </figure>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer data={data.footer} nav={data.nav} contact={data.contact} social={data.social} />

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox__close" id="lightboxClose" aria-label="Close">&times;</button>
    <button class="lightbox__nav lightbox__nav--prev" id="lightboxPrev" aria-label="Previous image">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--next" id="lightboxNext" aria-label="Next image">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
    </button>
    <div class="lightbox__inner" id="lightboxInner"></div>
    <p class="lightbox__caption" id="lightboxCaption"></p>
    <p class="lightbox__counter" id="lightboxCounter"></p>
  </div>

  <script>
    const lb = document.getElementById("lightbox");
    const inner = document.getElementById("lightboxInner");
    const cap = document.getElementById("lightboxCaption");
    const counter = document.getElementById("lightboxCounter");
    const closeBtn = document.getElementById("lightboxClose");
    const prevBtn = document.getElementById("lightboxPrev");
    const nextBtn = document.getElementById("lightboxNext");
    const figs = Array.from(document.querySelectorAll<HTMLElement>(".gallery__item"));
    let idx = -1;

    function render(i: number) {
      if (!inner || !cap || !counter) return;
      const fig = figs[i];
      const media = fig.getAttribute("data-media") || "";
      const isVid = fig.getAttribute("data-video") === "1";
      const caption = fig.getAttribute("data-caption") || "";
      inner.innerHTML = "";
      if (isVid) {
        const v = document.createElement("video");
        v.src = media;
        v.controls = true;
        v.autoplay = true;
        v.playsInline = true;
        v.className = "lightbox__media";
        inner.appendChild(v);
      } else {
        const img = document.createElement("img");
        img.src = media;
        img.alt = caption;
        img.className = "lightbox__media";
        inner.appendChild(img);
      }
      cap.textContent = caption;
      counter.textContent = `${i + 1} / ${figs.length}`;
    }

    function openItem(i: number) {
      if (!lb) return;
      idx = i;
      render(i);
      lb.classList.add("open");
      lb.setAttribute("aria-hidden", "false");
      document.documentElement.style.overflow = "hidden";
    }

    function close() {
      if (!lb || !inner) return;
      lb.classList.remove("open");
      lb.setAttribute("aria-hidden", "true");
      inner.innerHTML = "";
      document.documentElement.style.overflow = "";
    }

    function go(dir: number) {
      if (!figs.length) return;
      idx = (idx + dir + figs.length) % figs.length;
      render(idx);
    }

    figs.forEach((fig, i) => {
      fig.addEventListener("click", () => openItem(i));
    });
    closeBtn?.addEventListener("click", close);
    prevBtn?.addEventListener("click", (e) => { e.stopPropagation(); go(-1); });
    nextBtn?.addEventListener("click", (e) => { e.stopPropagation(); go(1); });
    lb?.addEventListener("click", (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener("keydown", (e) => {
      if (!lb || !lb.classList.contains("open")) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowRight") go(1);
      else if (e.key === "ArrowLeft") go(-1);
    });

    // Autoplay muted video previews when they scroll into view
    const vids = document.querySelectorAll<HTMLVideoElement>(".gallery__videowrap video");
    if (vids.length) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          const v = en.target as HTMLVideoElement;
          if (en.isIntersecting) v.play().catch(() => {});
          else v.pause();
        });
      }, { threshold: 0.4 });
      vids.forEach((v) => io.observe(v));
    }
  </script>
</Layout>
